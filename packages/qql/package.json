{
  "name": "@cruncher/qql",
  "version": "0.4.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/IamShobe/cruncher"
  },
  "description": "QQL query language for Cruncher platform.",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./grammar": {
      "types": "./dist/grammar.d.ts",
      "default": "./dist/grammar.js"
    },
    "./searchTree": {
      "types": "./dist/searchTree.d.ts",
      "default": "./dist/searchTree.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "bash scripts/generate.sh",
    "generate:watch": "chokidar 'src/syntax/*.g4' --initial -c 'bash scripts/generate.sh'",
    "build": "tsc --project tsconfig.json",
    "test": "vitest run",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "prepublishOnly": "npm run generate && npm run build"
  },
  "keywords": [
    "cruncher",
    "qql",
    "query-language"
  ],
  "author": {
    "name": "Elran Shefer"
  },
  "license": "GPL-3.0-only",
  "dependencies": {
    "antlr4ng": "^3.0.16"
  },
  "devDependencies": {
    "antlr4ng-cli": "^2.0.0",
    "chokidar-cli": "^3.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
