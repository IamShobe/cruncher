{
  "name": "@cruncher/adapter-grafana-loki-browser",
  "version": "0.3.0",
  "description": "Grafana Loki browser adapter for Cruncher.",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cruncher",
    "qql",
    "query-language",
    "grafana-loki",
    "adapter"
  ],
  "author": {
    "name": "Elran Shefer"
  },
  "license": "GPL-3.0-only",
  "dependencies": {
    "@cruncher/adapter-loki": "workspace:*",
    "@cruncher/adapter-utils": "workspace:*",
    "@cruncher/qql": "workspace:*",
    "async-mutex": "^0.5.0",
    "regex-escape": "^3.4.11",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/regex-escape": "^3.4.1",
    "typescript": "^5.9.3"
  }
}
