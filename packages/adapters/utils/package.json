{
  "name": "@cruncher/adapter-utils",
  "version": "0.3.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/IamShobe/cruncher"
  },
  "description": "Utility functions for Cruncher adapters.",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./formatters": {
      "default": "./dist/formatters.js",
      "types": "./dist/formatters.d.ts"
    },
    "./logTypes": {
      "default": "./dist/logTypes.js",
      "types": "./dist/logTypes.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cruncher",
    "qql",
    "query-language",
    "coralogix",
    "adapter"
  ],
  "author": {
    "name": "Elran Shefer"
  },
  "license": "GPL-3.0-only",
  "dependencies": {
    "@cruncher/qql": "workspace:*",
    "@cruncher/utils": "workspace:*",
    "@date-fns/utc": "^2.1.1",
    "date-fns": "^4.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
