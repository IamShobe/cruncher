{
  "name": "@cruncher/adapter-loki",
  "version": "0.2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/IamShobe/cruncher"
  },
  "description": "",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./query": {
      "default": "./dist/query.js",
      "types": "./dist/query.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "test": "vitest run",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cruncher",
    "qql",
    "query-language",
    "adapter"
  ],
  "license": "GPL-3.0-only",
  "dependencies": {
    "@cruncher/adapter-utils": "workspace:*",
    "@cruncher/qql": "workspace:*",
    "@types/regex-escape": "^3.4.1",
    "regex-escape": "^3.4.11",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
