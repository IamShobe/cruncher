#!/usr/bin/env bash
# Fake kubectl binary for testing @cruncher/adapter-k8s
# Parses enough of the kubectl CLI surface to satisfy the adapter.

set -euo pipefail

# ── helpers ────────────────────────────────────────────────────────────────────

now_iso() {
  # RFC3339Nano timestamp, optionally offset by $1 seconds (negative = past)
  local offset="${1:-0}"
  if [[ "$(uname)" == "Darwin" ]]; then
    date -u -v"${offset}S" "+%Y-%m-%dT%H:%M:%S.000000000Z" 2>/dev/null \
      || date -u "+%Y-%m-%dT%H:%M:%S.000000000Z"
  else
    date -u -d "${offset} seconds" "+%Y-%m-%dT%H:%M:%S.000000000Z" 2>/dev/null \
      || date -u "+%Y-%m-%dT%H:%M:%S.000000000Z"
  fi
}

# ── argument parsing ────────────────────────────────────────────────────────────

NAMESPACE="default"
SUBCOMMAND=""
RESOURCE=""
POD_NAME=""
CONTAINER=""
OUTPUT_FORMAT=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --context) shift; shift ;;            # ignore context
    -n|--namespace) NAMESPACE="$2"; shift; shift ;;
    -o|--output) OUTPUT_FORMAT="$2"; shift; shift ;;
    -c) CONTAINER="$2"; shift; shift ;;
    --timestamps|--since-time=*|--since=*) shift ;;   # ignore, return all logs
    get|logs) SUBCOMMAND="$1"; shift ;;
    pods) RESOURCE="pods"; shift ;;
    *) POD_NAME="$1"; shift ;;
  esac
done

