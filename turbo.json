{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:renderer": {
      "dependsOn": ["^build:renderer"],
      "outputs": [".vite/build/renderer/**"]
    },
    "build:main": {
      "dependsOn": ["^build:main"],
      "outputs": [".vite/build/main/**"]
    },
    "build:server": {
      "dependsOn": ["^build:server"],
      "outputs": [".vite/build/server/**"]
    },
    "prepare-server-runtime": {
      "dependsOn": ["build:server", "^build"],
      "outputs": ["resources/server/**"],
      "env": ["FAST"],
      "cache": true
    },
    "package": {
      "dependsOn": ["prepare-server-runtime", "build:renderer", "build:main"],
      "outputs": ["out/**"],
      "cache": true
    },
    "publish": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "lint": {
      "cache": true
    },
    "format": {
      "outputs": [],
      "cache": true
    },
    "format:check": {
      "cache": true
    },
    "serve": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "watch-routes": {
      "cache": false,
      "persistent": true
    },
    "generate:watch": {
      "cache": false,
      "persistent": true
    }
  }
}
