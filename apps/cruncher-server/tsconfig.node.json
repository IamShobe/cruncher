{
  "compilerOptions": {
    "target": "ESNext",
    "module": "esnext",
    "skipLibCheck": true,
    "allowJs": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "baseUrl": ".",
    "outDir": "dist",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "paths": {
      "~lib/*": [
        "./src/lib/*"
      ]
    },
    "types": ["node", "electron"],
    "strict": true
  },
  "include": [
    "./*.mts",
    "./src/**/*"
  ],
  "exclude": [
    "./dist",
    "./node_modules"
  ]
}
