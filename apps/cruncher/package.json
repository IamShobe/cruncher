{
  "name": "cruncher",
  "productName": "cruncher",
  "version": "2.4.0",
  "private": true,
  "description": "Cruncher main application - a tool for analyzing and processing data efficiently.",
  "main": ".vite/build/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/IamShobe/cruncher.git",
    "directory": "apps/cruncher"
  },
  "scripts": {
    "serve": "electron-forge start",
    "serve:inspect": "electron-forge start --inspect-electron",
    "clean-server-runtime": "node -e \"require('fs').rmSync('resources/server',{recursive:true,force:true})\"",
    "rebuild-server-native": "electron-rebuild --module-dir resources/server --only better-sqlite3,@duckdb/node-api --force",
    "prepare-server-runtime": "node scripts/prepare-server-runtime.mjs",
    "prepare-server-runtime:fast": "FAST=1 node scripts/prepare-server-runtime.mjs",
    "package": "pnpm run generate-routes && pnpm -w turbo run prepare-server-runtime --filter=cruncher && electron-forge package",
    "package:fast": "pnpm run generate-routes && FAST=1 pnpm -w turbo run prepare-server-runtime --filter=cruncher && electron-forge package",
    "make": "pnpm run generate-routes && pnpm -w turbo run prepare-server-runtime --filter=cruncher && electron-forge make",
    "make:fast": "pnpm run generate-routes && FAST=1 pnpm -w turbo run prepare-server-runtime --filter=cruncher && electron-forge make",
    "generate-routes": "tsr generate",
    "watch-routes": "tsr watch",
    "publish": "pnpm -w turbo run prepare-server-runtime --filter=cruncher && electron-forge publish",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "test": "CRUNCHER_FAST_TESTS=1 node ../../scripts/electron-vitest.mjs run",
    "test:watch": "node ../../scripts/electron-vitest.mjs --watch",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "build:main": "vite build --config vite.main.config.mts --outDir .vite/build/main",
    "build:renderer": "vite build --config vite.renderer.config.mts --outDir .vite/build/renderer",
    "typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json --noEmit"
  },
  "keywords": [],
  "author": {
    "name": "Elran Shefer"
  },
  "license": "GPL-3.0-only",
  "devDependencies": {
    "cruncher-server": "workspace:*",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron-forge/shared-types": "^7.11.1",
    "@electron/fuses": "^2.1.0",
    "@tanstack/devtools-vite": "^0.5.3",
    "@tanstack/router-cli": "^1.166.2",
    "@tanstack/router-plugin": "^1.166.2",
    "@types/d3-scale": "^4.0.9",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^40.8.0",
    "less": "^4.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.34.0",
    "@cruncher/adapter-utils": "workspace:*",
    "@cruncher/qql": "workspace:*",
    "@cruncher/server-shared": "workspace:*",
    "@cruncher/utils": "workspace:*",
    "@date-fns/utc": "^2.1.1",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@floating-ui/react": "^0.27.19",
    "@tanstack/react-devtools": "^0.9.10",
    "@tanstack/react-pacer": "^0.20.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.154.14",
    "@tanstack/react-router-devtools": "^1.154.14",
    "@tanstack/react-virtual": "^3.13.21",
    "@trpc/client": "^11.12.0",
    "@trpc/server": "^11.12.0",
    "ansicolor": "^2.0.3",
    "async-mutex": "^0.5.0",
    "chokidar": "^5.0.0",
    "compare-versions": "^6.1.1",
    "d3-scale": "^4.0.2",
    "date-fns": "^4.1.0",
    "electron-log": "^5.4.3",
    "electron-squirrel-startup": "^1.0.1",
    "immer": "^11.1.4",
    "jotai": "^2.18.0",
    "jotai-zustand": "^0.6.0",
    "lodash-es": "^4.17.23",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-icons": "^5.6.0",
    "react-shadow": "^20.6.0",
    "react-use": "^17.6.0",
    "react-virtuoso": "^4.18.3",
    "recharts": "^3.8.0",
    "solid-js": "1.9.11",
    "utf-8-validate": "^6.0.6",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  }
}
