{
  "name": "cruncher",
  "productName": "cruncher",
  "version": "2.1.2",
  "private": true,
  "description": "Cruncher main application - a tool for analyzing and processing data efficiently.",
  "main": ".vite/build/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/IamShobe/cruncher.git",
    "directory": "apps/cruncher"
  },
  "scripts": {
    "serve": "electron-forge start",
    "serve:inspect": "electron-forge start --inspect-electron",
    "package": "pnpm run generate-routes && electron-forge package",
    "make": "pnpm run generate-routes && electron-forge make",
    "generate-routes": "tsr generate",
    "watch-routes": "tsr watch",
    "publish": "electron-forge publish",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "test": "vitest run",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "build:server": "vite build --config vite.server.config.mts",
    "typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json --noEmit"
  },
  "keywords": [],
  "author": {
    "name": "Elran Shefer"
  },
