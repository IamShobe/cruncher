---
interface Props {
  name: string;
  type: string;
  description: string;
  link: string;
  icon?: string;
}

const { name, type, description, link, icon = "🔌" } = Astro.props;
---

<a href={link} class="adapter-card">
  <div class="adapter-card-header">
    <span class="adapter-icon">{icon}</span>
    <div>
      <h3>{name}</h3>
      <code class="adapter-type">{type}</code>
    </div>
  </div>
  <p class="adapter-description">{description}</p>
  <div class="adapter-footer">
    <span class="learn-more">Learn more →</span>
  </div>
</a>

<style>
  .adapter-card,
  .adapter-card * {
    margin: 0;
    padding: 0;
  }

  .adapter-card {
    display: flex;
    flex-direction: column;
    padding: 1rem;
    border: 2px solid var(--sl-color-gray-5);
    border-radius: 8px;
    background: var(--sl-color-bg-panel);
    transition: all 0.3s ease;
    text-decoration: none;
    color: inherit;
    height: 100%;
    margin: 0 !important;
  }

  .adapter-card:hover {
    border-color: var(--sl-color-accent);
    background: linear-gradient(135deg, var(--sl-color-bg-panel) 0%, var(--sl-color-accent-low) 100%);
    transform: translateY(-2px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.12);
  }

  .adapter-card-header {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    align-items: flex-start;
  }

  .adapter-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .adapter-card-header h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
  }

  .adapter-type {
    display: inline-block;
    background: var(--sl-color-gray-6);
    padding: 0.25rem 0.5rem;
    border-radius: 3px;
    font-size: 0.75rem;
    margin-top: 0.25rem;
    color: var(--sl-color-gray-1);
    font-weight: 500;
    letter-spacing: 0.2px;
  }

  .adapter-description {
    flex-grow: 1;
    margin: 0 0 0.75rem 0;
    font-size: 0.85rem;
    line-height: 1.4;
    color: var(--sl-color-gray-2);
  }

  .adapter-footer {
    display: flex;
    justify-content: flex-end;
  }

  .learn-more {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--sl-color-accent);
  }

  .adapter-card:hover .learn-more {
    color: var(--sl-color-accent);
    font-weight: 600;
  }
</style>
