---
interface Props {
  name: string;
  type: string;
  description: string;
  link: string;
  icon?: string;
}

const { name, type, description, link, icon = "🔌" } = Astro.props;
---

<a href={link} class="adapter-card">
  <div class="adapter-card-inner">
    <div class="adapter-card-header">
      <span class="adapter-icon">{icon}</span>
      <div class="adapter-meta">
        <h3>{name}</h3>
        <code class="adapter-type">{type}</code>
      </div>
    </div>
    <p class="adapter-description">{description}</p>
  </div>
  <div class="adapter-footer">
    <span class="learn-more">Learn more <span class="arrow">→</span></span>
  </div>
</a>

<style>
  .adapter-card,
  .adapter-card * {
    margin: 0;
    padding: 0;
  }

  .adapter-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 12px;
    background: var(--sl-color-bg-panel);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
  }

  .adapter-card:hover {
    border-color: var(--sl-color-accent);
    box-shadow: 0 4px 20px color-mix(in srgb, var(--sl-color-accent) 15%, transparent);
    transform: translateY(-2px);
  }

  .adapter-card-inner {
    padding: 1.25rem;
    flex-grow: 1;
  }

  .adapter-card-header {
    display: flex;
    gap: 0.875rem;
    margin-bottom: 0.875rem;
    align-items: center;
  }

  .adapter-icon {
    font-size: 2rem;
    line-height: 1;
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--sl-color-gray-6);
    border-radius: 8px;
  }

  .adapter-meta {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .adapter-meta h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: var(--sl-color-text-heading);
    line-height: 1.2;
  }

  .adapter-type {
    display: inline-block;
    background: color-mix(in srgb, var(--sl-color-accent) 12%, transparent);
    color: var(--sl-color-accent);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.3px;
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 25%, transparent);
    width: fit-content;
  }

  .adapter-description {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--sl-color-gray-2);
  }

  .adapter-footer {
    padding: 0.625rem 1.25rem;
    border-top: 1px solid var(--sl-color-gray-6);
    background: color-mix(in srgb, var(--sl-color-gray-7, var(--sl-color-bg)) 50%, transparent);
    display: flex;
    justify-content: flex-end;
  }

  .learn-more {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--sl-color-accent);
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .arrow {
    transition: transform 0.2s ease;
    display: inline-block;
  }

  .adapter-card:hover .arrow {
    transform: translateX(3px);
  }
</style>
