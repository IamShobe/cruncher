---
interface DataType {
  name: string;
  description: string;
  example: string;
}

const types: DataType[] = [
  { name: 'NumberField', description: 'Integers and floats', example: '42, 3.14, -7' },
  { name: 'StringField', description: 'Text of any length', example: '"hello", "user@example.com"' },
  { name: 'DateField', description: 'Unix timestamps (ms)', example: '1677628800000' },
  { name: 'BooleanField', description: 'True or false', example: 'true, false' },
  { name: 'ArrayField', description: 'Arrays of mixed types', example: '["a", "b", "c"]' },
  { name: 'ObjectField', description: 'Nested objects', example: '{"key": "value"}' },
  { name: 'NullField', description: 'Missing or undefined', example: 'null' },
];
---

<div class="datatype-grid">
  {types.map((type) => (
    <div class="datatype-cell">
      <div class="datatype-cell-name">{type.name}</div>
      <div class="datatype-cell-desc">{type.description}</div>
      <code class="datatype-cell-example">{type.example}</code>
    </div>
  ))}
</div>

<style>
  .datatype-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.75rem;
    margin: 1.5rem 0;
  }

  .datatype-cell {
    display: flex;
    flex-direction: column;
    padding: 0.75rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 6px;
    background: var(--sl-color-bg-panel);
    transition: all 0.2s ease;
  }

  .datatype-cell:hover {
    border-color: var(--sl-color-accent);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transform: translateY(-1px);
  }

  .datatype-cell-name {
    font-weight: 600;
    color: var(--sl-color-accent);
    font-size: 0.9rem;
    margin-bottom: 0.25rem;
  }

  .datatype-cell-desc {
    font-size: 0.8rem;
    color: var(--sl-color-gray-2);
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .datatype-cell-example {
    background: var(--sl-color-gray-7);
    padding: 0.4rem 0.5rem;
    border-radius: 3px;
    font-size: 0.8rem;
    color: var(--sl-color-text);
    word-break: break-word;
    line-height: 1.3;
  }

  @media (max-width: 768px) {
    .datatype-grid {
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 0.6rem;
    }

    .datatype-cell {
      padding: 0.6rem;
    }

    .datatype-cell-name {
      font-size: 0.85rem;
    }

    .datatype-cell-example {
      font-size: 0.75rem;
    }
  }
</style>
