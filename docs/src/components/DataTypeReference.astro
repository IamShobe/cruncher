---
interface DataType {
  name: string;
  example: string;
}

const types: DataType[] = [
  { name: 'NumberField', example: '42, 3.14, -7' },
  { name: 'StringField', example: '"hello", "user@example.com"' },
  { name: 'DateField', example: '1677628800000' },
  { name: 'BooleanField', example: 'true, false' },
  { name: 'ArrayField', example: '["a", "b", "c"]' },
  { name: 'ObjectField', example: '{"key": "value"}' },
  { name: 'NullField', example: 'null' },
];
---

<div class="datatype-reference">
  {types.map((type) => (
    <div class="datatype-item">
      <code class="datatype-type">{type.name}</code>
      <span class="datatype-sep">→</span>
      <code class="datatype-value">{type.example}</code>
    </div>
  ))}
</div>

<style>
  .datatype-reference {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 1.5rem 0;
    font-family: 'Courier New', monospace;
  }

  .datatype-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    border-radius: 4px;
    background: var(--sl-color-gray-7);
    font-size: 0.9rem;
    transition: background 0.2s ease;
  }

  .datatype-item:hover {
    background: var(--sl-color-accent-low);
  }

  .datatype-type {
    background: var(--sl-color-accent);
    color: white;
    padding: 0.25rem 0.5rem;
    border-radius: 3px;
    font-weight: 600;
    font-size: 0.85rem;
    flex-shrink: 0;
  }

  .datatype-sep {
    color: var(--sl-color-gray-3);
    font-size: 0.85rem;
    flex-shrink: 0;
  }

  .datatype-value {
    color: var(--sl-color-text);
    flex: 1;
    word-break: break-word;
  }

  @media (max-width: 640px) {
    .datatype-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.35rem;
    }

    .datatype-sep {
      display: none;
    }

    .datatype-type {
      font-size: 0.8rem;
    }

    .datatype-value {
      font-size: 0.85rem;
    }
  }
</style>
