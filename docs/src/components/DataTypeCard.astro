---
interface Props {
  name: string;
  icon: string;
  description: string;
  example: string;
}

const { name, icon, description, example } = Astro.props;
---

<div class="datatype-card">
  <div class="datatype-header">
    <span class="datatype-icon">{icon}</span>
    <h3>{name}</h3>
  </div>

  <p class="datatype-description">{description}</p>

  <div class="datatype-example">
    <code>{example}</code>
  </div>
</div>

<style>
  .datatype-card {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 6px;
    padding: 0.75rem;
    background: var(--sl-color-bg-panel);
    transition: all 0.2s ease;
    display: flex;
    flex-direction: column;
  }

  .datatype-card:hover {
    border-color: var(--sl-color-accent);
    background: linear-gradient(135deg, var(--sl-color-bg-panel) 0%, var(--sl-color-accent-low) 100%);
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .datatype-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .datatype-icon {
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .datatype-header h3 {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .datatype-description {
    margin: 0 0 0.5rem 0;
    font-size: 0.8rem;
    line-height: 1.4;
    color: var(--sl-color-gray-2);
    flex-grow: 1;
  }

  .datatype-example {
    background: var(--sl-color-gray-7);
    border-radius: 3px;
    padding: 0.35rem 0.5rem;
  }

  .datatype-example code {
    background: transparent;
    padding: 0;
    font-size: 0.75rem;
    color: var(--sl-color-accent);
  }

  @media (max-width: 768px) {
    .datatype-card {
      padding: 0.6rem;
    }

    .datatype-header h3 {
      font-size: 0.9rem;
    }
  }
</style>
