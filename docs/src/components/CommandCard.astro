---
import QQLCode from './QQLCode.astro';

interface Props {
  name: string;
  description: string;
  syntax: string;
  example?: string;
  output?: 'table' | 'timechart' | 'logs' | 'none';
}

const { name, description, syntax, example, output = 'none' } = Astro.props;

const outputText: Record<string, string> = {
  table: 'Table',
  timechart: 'Timechart',
  logs: 'Logs',
  none: 'None',
};
---

<div class="command-card">
  <div class="command-header">
    <div>
      <h2>{name}</h2>
      {output && output !== 'none' && (
        <span class="output-badge" data-output={output}>
          {outputText[output] ?? output}
        </span>
      )}
    </div>
  </div>

  <p class="command-description">{description}</p>

  <div class="command-syntax">
    <label>Syntax</label>
    <code>{syntax}</code>
  </div>

  {example && (
    <div class="command-example">
      <label>Example</label>
      <QQLCode code={example} />
    </div>
  )}

  <slot />
</div>

<style>
  .command-card,
  .command-card * {
    margin: 0;
    padding: 0;
  }

  .command-card {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    padding: 1.5rem;
    background: var(--sl-color-bg-panel);
    margin: 1.5rem 0 !important;
  }

  .command-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
    gap: 1rem;
  }

  .command-header > div {
    flex: 1;
  }

  .command-header h2 {
    margin: 0 0 0.5rem 0;
    font-size: 1.5rem;
    word-break: break-word;
  }

  .output-badge {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .output-badge[data-output="table"] {
    background: color-mix(in srgb, var(--sl-color-blue) 20%, transparent);
    color: var(--sl-color-blue);
    border: 1px solid color-mix(in srgb, var(--sl-color-blue) 30%, transparent);
  }

  .output-badge[data-output="timechart"] {
    background: color-mix(in srgb, var(--sl-color-purple) 20%, transparent);
    color: var(--sl-color-purple);
    border: 1px solid color-mix(in srgb, var(--sl-color-purple) 30%, transparent);
  }

  .output-badge[data-output="logs"] {
    background: color-mix(in srgb, var(--sl-color-green) 20%, transparent);
    color: var(--sl-color-green);
    border: 1px solid color-mix(in srgb, var(--sl-color-green) 30%, transparent);
  }

  .command-description {
    margin: 0 0 1.25rem 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--sl-color-gray-2);
  }

  .command-syntax,
  .command-example {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .command-syntax label,
  .command-example label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--sl-color-gray-3);
  }

  .command-syntax code {
    background: var(--sl-color-gray-7);
    padding: 0.5rem 0.75rem;
    border-radius: 4px;
    font-size: 0.85rem;
    word-break: break-word;
    white-space: pre-wrap;
  }

  @media (max-width: 640px) {
    .command-header h2 {
      font-size: 1.25rem;
    }
  }
</style>

<style is:global>
  /* Remove the default vertical margin from QQLCode when used inside a CommandCard */
  .command-syntax .qql-code,
  .command-example .qql-code {
    margin: 0;
  }
</style>
