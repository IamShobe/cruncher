---
interface Stage {
  label: string;
  description: string;
  icon?: string;
  optional?: boolean;
}

interface StageGroup {
  group: true;
  label: string;
  stages: Stage[];
}

type Step = Stage | StageGroup;

interface Props {
  steps: Step[];
  title?: string;
}

const { steps, title } = Astro.props;

function isGroup(step: Step): step is StageGroup {
  return (step as StageGroup).group === true;
}

let ordinal = 0;
const numbered = steps.map((step) => ({ step, num: ++ordinal }));
---

<div class="pipeline-wrap">
  {title && <p class="pipeline-title">{title}</p>}

  <div class="pipeline-scroll">
  <div class="pipeline">
    {numbered.map(({ step, num }, i) => (
      <>
        {isGroup(step) ? (
          <div class="stage stage-group">
            <div class="stage-top">
              <span class="step-badge">{num}</span>
            </div>
            <div class="stage-label">{step.label}</div>
            <div class="group-stages">
              {step.stages.map((s) => (
                <div class="group-stage">
                  <span class="group-stage-icon">{s.icon || "⚙️"}</span>
                  <div>
                    <div class="group-stage-label">{s.label}</div>
                    <div class="stage-desc">{s.description}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ) : (
          <div class="stage">
            <div class="stage-top">
              <span class="step-badge">{num}</span>
              {(step as Stage).optional && <span class="optional-badge">optional</span>}
            </div>
            <div class="stage-icon-wrap">
              <span class="stage-icon">{(step as Stage).icon || "⚙️"}</span>
            </div>
            <div class="stage-label">{(step as Stage).label}</div>
            <div class="stage-desc">{(step as Stage).description}</div>
          </div>
        )}
        {i < steps.length - 1 && (
          <div class="connector" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M13 6l6 6-6 6"/>
            </svg>
          </div>
        )}
      </>
    ))}
  </div>
  </div>
</div>

<style>
  .pipeline-wrap,
  .pipeline-wrap * {
    margin: 0;
    padding: 0;
  }

  .pipeline-wrap {
    margin: 1.5rem 0 !important;
  }

  .pipeline-scroll {
    overflow-x: auto;
    display: flex;
    justify-content: center;
  }

  .pipeline-title {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--sl-color-gray-3);
    margin: 0 0 1rem 0 !important;
    text-align: center;
  }

  .pipeline {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    gap: 0;
    min-width: max-content;
  }

  /* ── Regular stage ── */
  .stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.25rem 1rem;
    background: var(--sl-color-bg-panel);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 12px;
    width: 11rem;
    flex-shrink: 0;
    transition: border-color 0.15s, box-shadow 0.15s;
    gap: 0.5rem;
  }

  .stage:hover {
    border-color: var(--sl-color-accent);
    box-shadow: 0 2px 12px color-mix(in srgb, var(--sl-color-accent) 15%, transparent);
  }

  .stage-top {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    justify-content: center;
  }

  .step-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.4rem;
    height: 1.4rem;
    background: var(--sl-color-accent);
    color: var(--sl-color-bg);
    font-size: 0.65rem;
    font-weight: 700;
    border-radius: 50%;
    flex-shrink: 0;
    line-height: 1;
  }

  .optional-badge {
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    color: var(--sl-color-gray-3);
    background: var(--sl-color-gray-6);
    padding: 0.1rem 0.4rem;
    border-radius: 10px;
  }

  .stage-icon-wrap {
    width: 2.75rem;
    height: 2.75rem;
    background: color-mix(in srgb, var(--sl-color-accent) 10%, var(--sl-color-bg));
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 20%, transparent);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0.25rem 0;
  }

  .stage-icon {
    font-size: 1.3rem;
    line-height: 1;
  }

  .stage-label {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--sl-color-text-heading);
    line-height: 1.2;
  }

  .stage-desc {
    font-size: 0.75rem;
    color: var(--sl-color-gray-2);
    line-height: 1.45;
  }

  /* ── Connector ── */
  .connector {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.25rem;
    color: var(--sl-color-gray-3);
    flex-shrink: 0;
  }

  .connector svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  /* ── Group ── */
  .stage.stage-group {
    align-items: stretch;
    text-align: left;
    gap: 0.4rem;
  }

  .stage.stage-group .stage-label {
    text-align: center;
  }

  .group-stages {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    width: 100%;
    border-top: 1px solid var(--sl-color-gray-6);
    padding-top: 0.5rem;
  }

  .group-stage {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .group-stage-icon {
    font-size: 0.85rem;
    flex-shrink: 0;
    line-height: 1;
  }

  .group-stage-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--sl-color-text);
    white-space: nowrap;
  }

  /* ── Responsive: stack vertically on narrow screens ── */
  @media (max-width: 700px) {
    .pipeline-wrap {
      overflow-x: visible;
    }

    .pipeline {
      flex-direction: column;
      align-items: stretch;
      min-width: unset;
    }

    .stage {
      flex-direction: row;
      text-align: left;
      align-items: flex-start;
      width: auto;
      gap: 0.75rem;
      padding: 1rem;
    }

    .stage-top {
      flex-direction: column;
      align-items: center;
      gap: 0.25rem;
    }

    .stage-icon-wrap {
      width: 2.25rem;
      height: 2.25rem;
      flex-shrink: 0;
      margin: 0;
    }

    .stage-icon {
      font-size: 1.1rem;
    }

    .connector {
      justify-content: center;
      padding: 0.25rem 0;
      transform: rotate(90deg);
    }
  }
</style>
