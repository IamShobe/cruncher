---
interface Shortcut {
  action: string;
  mac: string;
  windows: string;
}

interface Group {
  label: string;
  shortcuts: Shortcut[];
}

interface Props {
  groups: Group[];
}

const { groups } = Astro.props;

function splitKeys(combo: string): string[] {
  return combo.split(" + ");
}
---

<div class="kb-wrap">
  <table class="kb-table">
    <thead>
      <tr>
        <th>Action</th>
        <th>Mac</th>
        <th>Windows</th>
      </tr>
    </thead>
    <tbody>
      {groups.map((group) => (
        <>
          <tr class="kb-group-row">
            <td colspan="3">{group.label}</td>
          </tr>
          {group.shortcuts.map((s) => (
            <tr class="kb-row">
              <td class="kb-action">{s.action}</td>
              <td>
                <div class="kb-keys">
                  {splitKeys(s.mac).map((k, i) => (
                    <>
                      {i > 0 && <span class="kb-plus">+</span>}
                      <kbd>{k}</kbd>
                    </>
                  ))}
                </div>
              </td>
              <td>
                <div class="kb-keys">
                  {splitKeys(s.windows).map((k, i) => (
                    <>
                      {i > 0 && <span class="kb-plus">+</span>}
                      <kbd>{k}</kbd>
                    </>
                  ))}
                </div>
              </td>
            </tr>
          ))}
        </>
      ))}
    </tbody>
  </table>
</div>

<style>
  .kb-wrap {
    margin: 1.5rem 0;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    overflow: hidden;
  }

  .kb-table {
    display: table !important;
    width: 100% !important;
    margin: 0 !important;
    border-collapse: collapse !important;
    border-spacing: 0 !important;
    font-size: 0.875rem;
  }

  thead th {
    padding: 0.6rem 1rem;
    text-align: left;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sl-color-gray-3);
    background: var(--sl-color-bg-nav);
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  .kb-group-row td {
    padding: 0.4rem 1rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sl-color-accent);
    background: var(--sl-color-bg-nav);
    border-top: 1px solid var(--sl-color-gray-5);
    border-bottom: 1px solid var(--sl-color-gray-6);
  }

  .kb-row td {
    padding: 0.55rem 1rem;
    border-bottom: 1px solid var(--sl-color-gray-6);
    vertical-align: middle;
  }

  .kb-row:last-child td {
    border-bottom: none;
  }

  .kb-row:hover td {
    background: var(--sl-color-bg-sidebar);
  }

  .kb-action {
    color: var(--sl-color-text);
    font-weight: 500;
    white-space: nowrap;
  }

  .kb-keys {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    white-space: nowrap;
  }

  kbd {
    display: inline-block;
    padding: 0.15em 0.45em;
    font-family: 'Monaco', 'Menlo', 'Consolas', monospace;
    font-size: 0.78rem;
    font-style: normal;
    line-height: 1.4;
    color: var(--sl-color-text);
    background: var(--sl-color-bg-panel);
    border: 1px solid var(--sl-color-gray-4);
    border-bottom-width: 2px;
    border-radius: 4px;
    box-shadow: none;
  }

  .kb-plus {
    color: var(--sl-color-gray-3);
    font-size: 0.7rem;
    user-select: none;
  }

  @media (max-width: 600px) {
    thead th:last-child,
    .kb-row td:last-child,
    .kb-group-row td {
      display: none;
    }

    thead th:nth-child(2) {
      content: 'Shortcut';
    }
  }
</style>
