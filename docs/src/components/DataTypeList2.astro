---
interface DataType {
  name: string;
  description: string;
  example: string;
}

const types: DataType[] = [
  { name: 'string', description: 'Text of any length', example: '"hello", "user@example.com"' },
  { name: 'number', description: 'Integers and floats', example: '42, 3.14, -7' },
  { name: 'boolean', description: 'True or false values', example: 'true, false' },
  { name: 'null', description: 'Missing or undefined values', example: 'null' },
  { name: 'object', description: 'Nested objects with properties', example: '{"key": "value"}' },
  { name: 'array', description: 'Arrays of mixed types', example: '["a", "b", "c"]' },
  { name: 'regex', description: 'Regular expression patterns', example: '`^Error:.*`' },
];
---

<div class="datatype-list">
  {types.map((type) => (
    <div class="datatype-item">
      <div class="datatype-header">
        <code class="datatype-name">{type.name}</code>
        <span class="datatype-desc">{type.description}</span>
      </div>
      <code class="datatype-example">{type.example}</code>
    </div>
  ))}
</div>

<style>
  .datatype-list,
  .datatype-list * {
    margin: 0;
    padding: 0;
  }

  .datatype-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 1.5rem 0;
  }

  .datatype-item {
    padding: 0.75rem;
    border-left: 3px solid var(--sl-color-accent);
    background: var(--sl-color-gray-7);
    border-radius: 4px;
    transition: all 0.2s ease;
  }

  .datatype-item:hover {
    background: var(--sl-color-accent-low);
    border-left-color: var(--sl-color-accent);
  }

  .datatype-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  .datatype-name {
    font-weight: 600;
    color: var(--sl-color-accent);
    font-size: 0.9rem;
    background: var(--sl-color-bg);
    padding: 0.25rem 0.5rem;
    border-radius: 3px 3px 0 0;
  }

  .datatype-desc {
    color: var(--sl-color-gray-2);
    font-size: 0.85rem;
    font-style: italic;
    font-weight: normal;
  }

  .datatype-example {
    display: block;
    background: var(--sl-color-bg);
    padding: 0.4rem 0.6rem;
    border-radius: 0 3px 3px 3px;
    font-size: 0.85rem;
    color: var(--sl-color-text);
    word-break: break-all;
  }

  @media (max-width: 640px) {
    .datatype-list {
      gap: 0.6rem;
    }

    .datatype-item {
      padding: 0.6rem;
    }

    .datatype-header {
      flex-direction: column;
      gap: 0.3rem;
      margin-bottom: 0.4rem;
    }

    .datatype-name {
      font-size: 0.85rem;
    }

    .datatype-desc {
      font-size: 0.8rem;
    }

    .datatype-example {
      font-size: 0.8rem;
    }
  }
</style>
