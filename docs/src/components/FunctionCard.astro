---
interface Props {
  name: string;
  description: string;
  category: 'boolean' | 'number' | 'string' | 'conditional';
  signature: string;
  returnType: string;
  returnDescription?: string;
}

const { name, description, category, signature, returnType, returnDescription } = Astro.props;

const categoryText: Record<string, { text: string; icon: string }> = {
  boolean: { text: 'Boolean', icon: '✓' },
  number: { text: 'Number', icon: '🔢' },
  string: { text: 'String', icon: '📝' },
  conditional: { text: 'Conditional', icon: '⚡' },
};

const { text, icon } = categoryText[category] ?? categoryText.string;
---

<div class="function-card">
  <div class="function-header">
    <div>
      <h3>{name}</h3>
      <span class="category-badge" data-category={category}>
        {icon} {text}
      </span>
    </div>
  </div>

  <p class="function-description">{description}</p>

  <div class="function-details">
    <div class="detail-group">
      <label>Signature</label>
      <code class="signature">{signature}</code>
    </div>
    <div class="detail-group">
      <label>Returns</label>
      <div class="return-info">
        <code class="return-type">{returnType}</code>
        {returnDescription && <p class="return-desc">{returnDescription}</p>}
      </div>
    </div>
  </div>

  <slot />
</div>

<style>
  .function-card,
  .function-card * {
    margin: 0;
    padding: 0;
  }

  .function-card {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    padding: 1.5rem;
    background: var(--sl-color-bg-panel);
    margin: 1.5rem 0 !important;
  }

  :global(.sl-markdown-content) .function-card {
    margin-top: 1.5rem !important;
    margin-bottom: 1.5rem !important;
  }

  .function-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
    gap: 1rem;
  }

  .function-header > div {
    flex: 1;
  }

  .function-header h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.25rem;
    word-break: break-word;
  }

  .category-badge {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .category-badge[data-category="boolean"] {
    background: color-mix(in srgb, var(--sl-color-purple) 20%, transparent);
    color: var(--sl-color-purple);
    border: 1px solid color-mix(in srgb, var(--sl-color-purple) 30%, transparent);
  }

  .category-badge[data-category="number"] {
    background: color-mix(in srgb, var(--sl-color-blue) 20%, transparent);
    color: var(--sl-color-blue);
    border: 1px solid color-mix(in srgb, var(--sl-color-blue) 30%, transparent);
  }

  .category-badge[data-category="string"] {
    background: color-mix(in srgb, var(--sl-color-green) 20%, transparent);
    color: var(--sl-color-green);
    border: 1px solid color-mix(in srgb, var(--sl-color-green) 30%, transparent);
  }

  .category-badge[data-category="conditional"] {
    background: color-mix(in srgb, var(--sl-color-orange) 20%, transparent);
    color: var(--sl-color-orange);
    border: 1px solid color-mix(in srgb, var(--sl-color-orange) 30%, transparent);
  }

  .function-description {
    margin: 0 0 1.25rem 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--sl-color-gray-2);
  }

  .function-details {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 1rem;
    padding: 1rem;
    background: var(--sl-color-gray-7);
    border-radius: 6px;
  }

  .detail-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .detail-group label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--sl-color-gray-3);
  }

  .signature,
  .return-type {
    background: var(--sl-color-bg);
    padding: 0.5rem 0.75rem;
    border-radius: 4px;
    font-size: 0.85rem;
    overflow-x: auto;
    word-break: break-word;
  }

  .return-info {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .return-desc {
    margin: 0;
    font-size: 0.8rem;
    color: var(--sl-color-gray-2);
    line-height: 1.5;
    font-style: italic;
  }

  @media (max-width: 640px) {
    .function-details {
      grid-template-columns: 1fr;
    }
  }
</style>
