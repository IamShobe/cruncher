---
interface Props {
  name: string;
  description: string;
  category: 'boolean' | 'number' | 'string' | 'conditional';
  signature: string;
  returnType: string;
  returnDescription?: string;
}

const { name, description, category, signature, returnType, returnDescription } = Astro.props;

const categoryColors: Record<string, { bg: string; text: string; icon: string }> = {
  boolean: { bg: 'rgb(139, 92, 246)', text: 'Boolean', icon: '✓' },
  number: { bg: 'rgb(59, 130, 246)', text: 'Number', icon: '🔢' },
  string: { bg: 'rgb(34, 197, 94)', text: 'String', icon: '📝' },
  conditional: { bg: 'rgb(249, 115, 22)', text: 'Conditional', icon: '⚡' },
};

const { bg, text, icon } = categoryColors[category] || categoryColors.string;
---

<div class="function-card">
  <div class="function-header">
    <div>
      <h3>{name}</h3>
      <span class="category-badge" style={`background-color: ${bg}`}>
        {icon} {text}
      </span>
    </div>
  </div>

  <p class="function-description">{description}</p>

  <div class="function-details">
    <div class="detail-group">
      <label>Signature</label>
      <code class="signature">{signature}</code>
    </div>
    <div class="detail-group">
      <label>Returns</label>
      <div class="return-info">
        <code class="return-type">{returnType}</code>
        {returnDescription && <p class="return-desc">{returnDescription}</p>}
      </div>
    </div>
  </div>

  <slot />
</div>

<style>
  .function-card {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    padding: 1.5rem;
    background: var(--sl-color-bg-panel);
    margin: 1.5rem 0 !important;
  }

  :global(.sl-markdown-content) .function-card {
    margin-top: 1.5rem !important;
    margin-bottom: 1.5rem !important;
  }

  .function-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
  }

  .function-header h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.25rem;
  }

  .category-badge {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    border-radius: 20px;
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .function-description {
    margin: 0 0 1.25rem 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--sl-color-gray-2);
  }

  .function-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
    padding: 1rem;
    background: var(--sl-color-gray-7);
    border-radius: 6px;
  }

  .detail-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .detail-group label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--sl-color-gray-3);
  }

  .signature,
  .return-type {
    background: var(--sl-color-bg);
    padding: 0.5rem 0.75rem;
    border-radius: 4px;
    font-size: 0.85rem;
    overflow-x: auto;
  }

  .return-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .return-desc {
    margin: 0;
    font-size: 0.8rem;
    color: var(--sl-color-gray-2);
    line-height: 1.4;
    font-style: italic;
  }

  @media (max-width: 640px) {
    .function-details {
      grid-template-columns: 1fr;
    }
  }
</style>
